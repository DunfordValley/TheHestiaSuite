# Copy this file to .env and fill in your values
# Never commit .env to version control

# Database password (change this in production!)
POSTGRES_PASSWORD=SecurePassword123

# Cloudflare Zero Trust Tunnel token (from Cloudflare Dashboard > Zero Trust > Tunnels)
# Only needed when running with --profile production
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

# Gmail Integration (optional — enables email features)
# Create credentials at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Enable the Gmail API first, then create a Web application OAuth client.
# Add both redirect URIs to the client:
#   Dev:  http://localhost:5173/api/gmail/callback
#   Prod: https://crm.yourcompany.com/api/gmail/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Must match the redirect URI registered in Google Cloud Console for your environment
GOOGLE_REDIRECT_URI=https://crm.yourcompany.com/api/gmail/callback

# Publicly reachable base URL — used to construct the open-tracking pixel URL
# Production: your Cloudflare tunnel domain (no trailing slash)
# Development: http://localhost:3001
PUBLIC_URL=https://crm.yourcompany.com

# Gmail inbox sync interval in milliseconds (default: 300000 = 5 minutes)
# GMAIL_SYNC_INTERVAL_MS=300000
